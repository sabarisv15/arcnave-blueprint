# Migration-owner role (superuser created by the postgres image).
# backend/scripts/migrate.js (node-pg-migrate) connects as this role
# — never the running app.
POSTGRES_USER=arcnave_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=arcnave

# Least-privilege runtime role the Express app connects as. Created
# by docker/postgres/init/01-app-role.sh at first container boot —
# subject to RLS, unlike POSTGRES_USER. See ADR-002.
ARCNAVE_APP_PASSWORD=change-me-too

# Least-privilege runtime role the Super Admin Portal API connects
# as. Created by docker/postgres/init/02-platform-role.sh — granted
# only on platform_admins/colleges/principal_invitations, nothing on
# tenant tables. See ADR-015.
ARCNAVE_PLATFORM_PASSWORD=change-me-platform

# Signs/verifies tenant access JWTs (HS256). Generate a real random
# value — e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
# — never reuse this placeholder outside local dev.
JWT_SECRET_KEY=change-me-again

# Signs/verifies platform-admin access JWTs. Deliberately a DIFFERENT
# value from JWT_SECRET_KEY — never reuse that one here, or a tenant
# and a platform token become indistinguishable by signature alone.
PLATFORM_JWT_SECRET_KEY=change-me-platform-jwt
