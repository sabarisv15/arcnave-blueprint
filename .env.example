# Migration-owner role (superuser created by the postgres image).
# backend/scripts/migrate.js (node-pg-migrate) connects as this role
# — never the running app.
POSTGRES_USER=arcnave_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=arcnave

# Least-privilege runtime role the Express app connects as. Created
# by docker/postgres/init/01-app-role.sh at first container boot —
# subject to RLS, unlike POSTGRES_USER. See ADR-002.
ARCNAVE_APP_PASSWORD=change-me-too

# Least-privilege runtime role the Super Admin Portal API connects
# as. Created by docker/postgres/init/02-platform-role.sh — granted
# only on platform_admins/colleges/principal_invitations, nothing on
# tenant tables. See ADR-015.
ARCNAVE_PLATFORM_PASSWORD=change-me-platform

# Signs/verifies tenant access JWTs (HS256). Generate a real random
# value — e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
# — never reuse this placeholder outside local dev.
JWT_SECRET_KEY=change-me-again

# Signs/verifies platform-admin access JWTs. Deliberately a DIFFERENT
# value from JWT_SECRET_KEY — never reuse that one here, or a tenant
# and a platform token become indistinguishable by signature alone.
PLATFORM_JWT_SECRET_KEY=change-me-platform-jwt

# Optional — how long a password-reset token stays acceptable (hours).
# Leave unset to use the default (2 hours).
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=2

# Optional — NotificationService's real email channel (Module 8).
# Leave SMTP_HOST unset to use the log-only stub fallback (the safe
# default for local dev/test — no real mail server required).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@arcnave.local

# Optional — Module 9's LLM step (services/llmProvider.js), an
# NVIDIA NIM API key (https://build.nvidia.com — OpenAI-compatible
# /chat/completions). Leave unset to run with the AI tool-invoke path
# working but the "ask a question about it" path 503ing cleanly.
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct

# Optional — Module 9's RAG slice (services/documentSearchService.js),
# the embedding model behind search_documents. A different model from
# NIM_MODEL above. Leave unset to use the default (nv-embedqa-e5-v5,
# purpose-built for retrieval); if you change it, note that
# ai_document_chunks' embedding column is a fixed vector(1024) width —
# a model with a different output dimension needs a new migration too.
NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Document storage safety. Use a real random value outside local dev.
DOCUMENT_STORAGE_ROOT=/app/storage
DOCUMENT_BACKUP_ROOT=/app/storage-backups
DOCUMENT_STORAGE_ENCRYPTION_KEY=local-dev-document-key-change-me
